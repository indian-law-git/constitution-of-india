# Pipeline working directory — uncached LLM responses, working PDFs, intermediate JSON.
# Do not commit. See PRD §5 and handoff §5.
pipeline/intermediate/
pipeline/.cache/
.cache/

# Reference source PDFs and OCR text — too large for git, kept locally.
# Provenance (URL + SHA-256) is recorded in metadata/provenance.json instead.
docs/*.pdf
docs/*.txt
docs/*.html
docs/*_files/

